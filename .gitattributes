# Default = LF (cross-platform consistency)
* text=auto eol=lf

# Force LF on text files
*.md      text eol=lf
*.html    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.txt     text eol=lf
*.json    text eol=lf
*.xml     text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.cff     text eol=lf
Gemfile   text eol=lf
LICENSE   text eol=lf

# GitHub Linguist : ce repo est de la documentation
*.md      linguist-documentation
*.html    linguist-documentation
docs/*    linguist-documentation

# Binaires
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.svg     binary
*.pdf     binary
*.ico     binary
